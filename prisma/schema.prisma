
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
 

model User {
  id String @id
  clerkId String @unique
  email String? @unique
  firstName String?
  lastName String?
  avatarUrl String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}